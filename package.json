{
  "name": "my-ckb-project",
  "version": "0.1.0",
  "description": "CKB JavaScript Smart Contract project",
  "private": true,
  "type": "module",
  "scripts": {
    "build:contract": "node scripts/build-contract.js",
    "build:contract:debug": "node scripts/build-contract.js --debug",
    "build": "node scripts/build-all.js",
    "build:debug": "node scripts/build-all.js --debug",
    "deploy": "node scripts/deploy.js",
    "deploy:build": "run-s build deploy",
    "deploy:debug": "run-s build:debug deploy",
    "test": "run-s build test:only",
    "test:only": "jest",
    "add-contract": "node scripts/add-contract.js",
    "clean": "rimraf dist",
    "format": "prettier --write .",
    "transfer": "parcel exercises/simple-transfer/index.html",
    "store-data": "parcel exercises/store-data-on-cell/index.html"
  },
  "dependencies": {
    "@ckb-js-std/bindings": "~1.0.0",
    "@ckb-js-std/core": "~1.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "dotenv": "^17.2.1",
    "parcel": "^2.16.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@ckb-ccc/core": "^1.12.2",
    "@types/jest": "~29.5.14",
    "@types/node": "~22.13.8",
    "ckb-testtool": "1.0.5",
    "esbuild": "~0.25.8",
    "jest": "~29.7.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.5.3",
    "rimraf": "^6.0.1",
    "ts-jest": "~29.2.6",
    "typescript": "~5.8.2"
  }
}
